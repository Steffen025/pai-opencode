{
  "$schema": "https://biomejs.dev/schemas/2.4.9/schema.json",
  "assist": {
    "enabled": false
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noEmptyBlockStatements": "off"
      }
    }
  },
  "formatter": {
    "enabled": false
  },
  "files": {
    "includes": [
      ".opencode/PAI/ACTIONS/**/*.ts",
      "*.ts",
      "*.js",
      "*.json"
    ]
  }
}